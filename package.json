{
  "name": "chrono-cli",
  "version": "1.0.0",
  "description": "AI-powered commit message generator using Google Gemini - A personal college project",
  "main": "dist/index.js",
  "private": true,
  "bin": {
    "chrono": "./dist/index.js"
  },
  "keywords": [
    "git",
    "commit",
    "ai",
    "gemini",
    "conventional-commits",
    "cli",
    "commit-message",
    "college-project",
    "educational"
  ],
  "author": "College Student",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kubrooo/chrono-cli"
  },
  "bugs": {
    "url": "https://github.com/Kubrooo/chrono-cli/issues"
  },
  "homepage": "https://github.com/Kubrooo/chrono-cli#readme",
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node ./dist/index.js",
    "dev": "tsx src/index.ts",
    "prepare": "npm run build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "@google/generative-ai": "^0.21.0",
    "conf": "^15.1.0",
    "dotenv": "^16.6.1",
    "execa": "^9.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/ui": "^4.0.18",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  }
}
